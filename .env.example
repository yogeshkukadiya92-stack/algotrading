# Monorepo
PROJECT_NAME=tradepilot-india

# Frontend
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
NEXT_PUBLIC_DEFAULT_PAPER_BROKER_ACCOUNT_ID=paper_zerodha_001
NEXT_PUBLIC_DEFAULT_LIVE_BROKER_ACCOUNT_ID=live_zerodha_001
NEXT_PUBLIC_ENABLE_LIVE_AUTO_TRADING=false

# API
APP_ENV=development
DATABASE_URL=postgresql+psycopg://tradepilot:tradepilot@postgres:5432/tradepilot
REDIS_URL=redis://redis:6379/0
JWT_SECRET=replace-with-a-32-char-jwt-secret-key
LIVE_TRADING_ENABLED=false
ENABLE_LIVE_BROKER_ORDERS=false
ENABLE_AUTO_TRADING=false
AUTO_TRADING_ENABLED=false
PAPER_TRADING=true
CORS_ORIGINS=["http://localhost:3000","http://localhost:3001","http://localhost:3010","http://localhost:3012","http://localhost:3013","http://127.0.0.1:3000","http://127.0.0.1:3001","http://127.0.0.1:3010","http://127.0.0.1:3012","http://127.0.0.1:3013"]

# Zerodha read-only adapter placeholders
ZERODHA_API_KEY=replace-with-zerodha-api-key
ZERODHA_ACCESS_TOKEN=replace-with-read-only-access-token
ZERODHA_REDIRECT_URI=http://localhost:3000/brokers
ZERODHA_API_BASE_URL=https://api.kite.trade
ZERODHA_OPTION_CHAIN_PATH=/option-chain

# Upstox read-only adapter placeholders
UPSTOX_API_KEY=replace-with-upstox-api-key
UPSTOX_ACCESS_TOKEN=replace-with-upstox-access-token
UPSTOX_REDIRECT_URI=http://localhost:3000/brokers
UPSTOX_API_BASE_URL=https://api.upstox.com

# Infrastructure placeholders
POSTGRES_DB=tradepilot
POSTGRES_USER=tradepilot
POSTGRES_PASSWORD=replace-with-strong-postgres-password
STATIC_IP_WHITELIST=
HTTP_PORT=80
BACKUP_DIR=./backups
